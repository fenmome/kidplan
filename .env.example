# KidPlan 环境变量配置

# ================================
# 管理员账号配置（必填）
# ================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# ================================
# JWT安全配置（必填）
# ================================
# 请修改为强密码，建议32位以上随机字符串
JWT_SECRET=your-256-bit-secret-key-here-please-change-it

# ================================
# 提醒配置（可选）
# ================================
# 默认提前提醒分钟数
DEFAULT_REMINDER_MINUTES=10

# ================================
# 部署配置（可选）
# ================================
# 前端访问端口，默认8080（避免与服务器其他服务冲突）
KIDPLAN_PORT=8080
